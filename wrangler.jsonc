{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "poof",
  "account_id": "9993650612175c36066a397a94466033",
  "main": "src/worker/index.ts",
  "compatibility_date": "2025-05-01",
  "observability": { "enabled": true },
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    // The worker is the front door: it must see "/", "/c/:id", "/llms.txt", and
    // "/health" to content-negotiate and publish the discovery doc (POOF-13). It
    // delegates to ASSETS for the SPA shell and static files via env.ASSETS.fetch.
    "run_worker_first": true
  },
  "durable_objects": {
    "bindings": [{ "name": "CLIP", "class_name": "ClipDO" }]
  },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["ClipDO"] }],
  "r2_buckets": [{ "binding": "R2", "bucket_name": "poof-content" }],
  "ratelimits": [
    { "name": "CREATE_LIMIT", "namespace_id": "1001", "simple": { "limit": 100, "period": 60 } }
  ],
  // TURNSTILE_SECRET is intentionally NOT a var: in production it is a real
  // secret set via `wrangler secret put TURNSTILE_SECRET`. Local dev and the test
  // pool read Cloudflare's public always-pass test key from .dev.vars (gitignored).
  "vars": {
    "MAX_CLIP_BYTES": "10485760",
    "INLINE_MAX_BYTES": "1048576"
  }
}
